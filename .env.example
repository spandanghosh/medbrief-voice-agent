# ─── Groq (free tier — get key at console.groq.com, no card required) ─────────
GROQ_API_KEY=gsk_your-groq-api-key-here

# ─── LLM ──────────────────────────────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile

# ─── STT (Groq Whisper) ───────────────────────────────────────────────────────
STT_MODEL=whisper-large-v3

# ─── TTS (edge-tts — Microsoft neural voices, completely free, no key needed) ─
# Full voice list: python -m edge_tts --list-voices
TTS_VOICE=en-US-AriaNeural

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=agent.direct
RABBITMQ_REQUEST_QUEUE=agent.requests
RABBITMQ_DLX=agent.dlx
RABBITMQ_DLQ=agent.dead_letters
RPC_TIMEOUT_SECONDS=30

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
SESSION_TTL=1800
MAX_HISTORY_TURNS=20

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB=medbrief

# ─── App ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
GATEWAY_PORT=8000

# ─── PubMed (optional — raises rate limit from 3 to 10 req/s) ────────────────
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
PUBMED_API_KEY=
